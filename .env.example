# DigiUniversity — example env. CONTRACT FILE ONLY.
#
# This file is committed to git. Real production values live in
# /var/www/digiuniversity/.env on the VPS (mode 0600), generated by:
#   .\scripts\remote.ps1 provision-env
# Rotation: .\scripts\remote.ps1 provision-env -Force
# See SECURITY.md for details.
#
# Variables marked REQUIRED below have NO default in docker-compose.yml —
# a missing .env will fail the api boot fast (compose-time error) rather
# than silently running with weak placeholders.

# ---------- Runtime ----------
NODE_ENV=production
TZ=Asia/Tehran

# Public origin (CDN/Caddy terminate TLS; container speaks plain HTTP)
APP_URL=https://digiuniversity.ir

# Host port that docker-compose binds for the frontend nginx
APP_PORT=8090

# Default locale
DEFAULT_LOCALE=fa
RTL_ENABLED=true

# ---------- Backend Core API (apps/api, NestJS) ----------
# The api is reached publicly via https://digiuniversity.ir/api/v1/...

# JWT signing key. REQUIRED. MUST be at least 32 chars. Rotating
# invalidates every session in the tenant. Generated by provision-env
# (64-char base64-safe, ~384 bits of entropy).
JWT_SECRET=<set-via-provision-env-rand-base64-64>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Field-level encryption key (32 bytes, base64-safe). REQUIRED for
# any future PII-at-rest column encryption. Generated by provision-env.
ENCRYPTION_KEY=<set-via-provision-env-rand-base64-32>

# PostgreSQL 16 (compose service: postgres)
POSTGRES_USER=digiuniversity
POSTGRES_PASSWORD=digiuniversity_dev
POSTGRES_DB=digiuniversity
DATABASE_URL=postgresql://digiuniversity:digiuniversity_dev@postgres:5432/digiuniversity?schema=public

# Seed control. RUN_SEED=true makes the api container run prisma/seed.ts
# after migrations apply, idempotently ensuring the demo tenant + admin
# exist. Phase-13 R2b flipped the compose default to RUN_SEED=false so
# production never auto-seeds on container recreate. Use:
#   .\scripts\remote.ps1 seed
# to run it explicitly on a freshly migrated DB.
RUN_SEED=false
SEED_TENANT_SLUG=demo
SEED_TENANT_NAME=DigiUniversity Demo
SEED_ADMIN_EMAIL=admin@digiuniversity.ir
# REQUIRED at compose-parse time even when RUN_SEED=false, so the api
# fails fast on a brand-new VPS without a fully provisioned .env.
SEED_ADMIN_PASSWORD=<set-via-provision-env-rand-24>

# Redis (cache + BullMQ)
REDIS_URL=redis://redis:6379

# Object storage (MinIO in dev, S3-compatible in prod)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=digiuniversity
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ---------- AI Gateway (apps/ai-gateway, FastAPI, future phase) ----------
# AI_MODE=mock                          # local stub responses (no network)
# AI_MODE=external_api                  # call AI_SERVICES_BASE_URL
AI_MODE=mock
AI_GATEWAY_URL=http://ai-gateway:8000
AI_SERVICES_BASE_URL=https://future-gpu-server.example.com
AI_SERVICES_API_KEY=<set-via-provision-env-rand-hex-64>
AI_TIMEOUT_SECONDS=120

# ---------- Live class provider (LiveKit / BigBlueButton, later) ----------
LIVECLASS_PROVIDER=mock
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---------- Observability ----------
LOG_LEVEL=info
SENTRY_DSN=
