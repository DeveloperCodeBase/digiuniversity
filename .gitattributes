# Normalise text files to LF in the repo, regardless of OS checkout.
# Without this, Windows clones get CRLF in shell scripts and nginx confs,
# which breaks them when the docker build copies them into the Linux image.
* text=auto eol=lf

# Force LF on every file that gets executed by a Unix shell or a Linux
# daemon. CRLF in any of these silently breaks at runtime: bash treats
# `\r` as part of the command, nginx rejects `\r` in directive values,
# and docker-compose `entrypoint` strings would inherit the bad bytes.
*.sh             text eol=lf
*.bash           text eol=lf
*.conf           text eol=lf
nginx.conf       text eol=lf
Dockerfile       text eol=lf
*.Dockerfile     text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf
docker-entrypoint.sh text eol=lf

# PowerShell stays CRLF because it's only executed on Windows.
*.ps1            text eol=crlf
*.psm1           text eol=crlf

# Binary assets — never normalise.
*.png            binary
*.jpg            binary
*.jpeg           binary
*.gif            binary
*.webp           binary
*.avif           binary
*.ico            binary
*.woff           binary
*.woff2          binary
*.ttf            binary
*.eot            binary
*.pdf            binary
*.docx           binary
*.zip            binary
*.gz             binary
*.sql.gz         binary
