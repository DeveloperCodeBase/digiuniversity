# MS Office lock files
~$*

# Internal artefacts kept locally but never shipped to repo or image
project-run.docx
uploads/
*.docx
!docs/**/*.docx

# Production secrets (per phase-13 hardening). Real values live on VPS
# only and are loaded from /var/www/digiuniversity/.env.production
# (chmod 600). .env.example stays whitelisted above as the contract.
.env.production
.env.production.*
*.env.local
*.env.backup

# TypeScript incremental build artefact (regenerated on every tsc run)
*.tsbuildinfo

# Database dumps (created by `remote.ps1 backup`, stored on VPS).
# Phase-15 R1 carve-out: Prisma migration .sql files MUST be tracked
# (they're the source-of-truth for schema changes). The negation must
# come AFTER the broader `*.sql` rule to override it.
*.sql
*.sql.gz
!apps/api/prisma/migrations/**/migration.sql
