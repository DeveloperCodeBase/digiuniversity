// DigiUniversity core schema — Phase 2.
//
// Source of truth for the auth + tenant + RBAC + AI audit layer. The
// university domain (Faculty, Course, Enrollment, ClassSession, …) lands
// in Phase 3 as additive migrations.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Tenants ----------
//
// Every domain row carries `tenantId`. We add an index per table so the
// "always filter by tenant" rule is also enforceable at the DB level.

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  roles           Role[]
  permissions     Permission[]
  refreshTokens   RefreshToken[]
  aiInteractions  AiInteractionLog[]
  faculties       Faculty[]
  departments     Department[]
  programs        Program[]
  courses         Course[]
  courseModules   CourseModule[]
  lessons         Lesson[]
  cohorts         Cohort[]
  enrollments     Enrollment[]
  classSessions   ClassSession[]
  recordings      Recording[]
  attendance      Attendance[]
  assessments     Assessment[]
  questions       Question[]
  submissions     Submission[]
  learningEvents  LearningEvent[]

  @@index([slug])
}

// ---------- Identity ----------

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String?
  locale       String   @default("fa")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  aiInteractions AiInteractionLog[]
  enrollments    Enrollment[]
  attendance     Attendance[]
  hostedSessions ClassSession[]     @relation("ClassSessionHost")
  submissions    Submission[]
  learningEvents LearningEvent[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ---------- RBAC ----------
//
// Roles and permissions are tenant-scoped so each tenant can shape its
// own access model. Three roles are seeded by default: admin, instructor,
// student. Permissions are colon-namespaced strings (resource:action).

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  name      String   // admin, instructor, student, ...
  label     String?  // human-readable, e.g. "مدیر سامانه"
  createdAt DateTime @default(now())

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id        String   @id @default(cuid())
  tenantId  String
  key       String   // e.g. "course:create", "user:invite"
  createdAt DateTime @default(now())

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ---------- Refresh tokens ----------
//
// Stored as the SHA-256 of the token (never the raw value) so a DB leak
// can't be used to mint sessions. Rotated on every /v1/auth/refresh call.

model RefreshToken {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ip         String?
  issuedAt   DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
}

// ---------- University domain ----------
//
// Org structure: Faculty → Department → Program → (Course | Cohort).
// Course content: Course → CourseModule → Lesson.
// Membership: Enrollment ties a User to a Course (optionally inside a
// Cohort). Every row carries `tenantId` (filtered on every read) plus
// the audit fields (`createdAt`, `updatedAt`, `createdBy`, `updatedBy`)
// and a nullable `deletedAt` for soft delete — see docs/ADRs/0005.

model Faculty {
  id          String    @id @default(cuid())
  tenantId    String
  slug        String
  name        String
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments Department[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([deletedAt])
}

model Department {
  id          String    @id @default(cuid())
  tenantId    String
  facultyId   String
  slug        String
  name        String
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  faculty  Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  programs Program[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([facultyId])
  @@index([deletedAt])
}

model Program {
  id                String    @id @default(cuid())
  tenantId          String
  departmentId      String
  slug              String
  name              String
  description       String?
  degreeLevel       String    // "bachelor" | "master" | "phd" | "certificate"
  durationSemesters Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses    Course[]
  cohorts    Cohort[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([departmentId])
  @@index([deletedAt])
}

model Course {
  id          String    @id @default(cuid())
  tenantId    String
  programId   String
  code        String    // human-friendly identifier, e.g. "CS101"
  title       String
  description String?
  credits     Int       @default(3)
  language    String    @default("fa")
  level       String?   // "beginner" | "intermediate" | "advanced"

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program        Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  modules        CourseModule[]
  enrollments    Enrollment[]
  classSessions  ClassSession[]
  assessments    Assessment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([programId])
  @@index([deletedAt])
}

model CourseModule {
  id          String    @id @default(cuid())
  tenantId    String
  courseId    String
  title       String
  description String?
  orderIndex  Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([tenantId])
  @@index([courseId])
  @@index([deletedAt])
}

model Lesson {
  id              String    @id @default(cuid())
  tenantId        String
  moduleId        String
  title           String
  contentMarkdown String?
  durationMinutes Int?
  orderIndex      Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([moduleId])
  @@index([deletedAt])
}

model Cohort {
  id        String    @id @default(cuid())
  tenantId  String
  programId String
  slug      String
  name      String
  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([programId])
  @@index([deletedAt])
}

model Enrollment {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  courseId    String
  cohortId    String?
  status      String    @default("active") // "active" | "completed" | "dropped" | "withdrawn"
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cohort Cohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId, courseId])
  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
  @@index([deletedAt])
}

// ---------- Class sessions, recordings, attendance ----------
//
// A ClassSession is one scheduled instance of a course meeting. It owns
// at most one Recording row (file metadata only — actual media lives in
// the storage abstraction described in docs/architecture/LIVE_CLASS.md).
// Attendance rows are appended when a user joins/leaves.
//
// `provider` + `providerMeetingId` + `joinUrl` are filled by whichever
// LiveClassProvider Nest resolves at boot (Phase 6 ships only the mock
// provider; LiveKit/BBB will plug in behind the same interface).

model ClassSession {
  id                String    @id @default(cuid())
  tenantId          String
  courseId          String
  hostUserId        String?   // instructor scheduling/leading the session
  title             String
  description       String?
  scheduledStart    DateTime
  scheduledEnd      DateTime
  actualStart       DateTime?
  actualEnd         DateTime?
  status            String    @default("scheduled") // scheduled | live | ended | cancelled
  joinPolicy        String    @default("enrolled")  // enrolled | public | invite
  provider          String    @default("mock")      // mock | livekit | bbb
  providerMeetingId String?
  joinUrl           String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course     Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  host       User?        @relation("ClassSessionHost", fields: [hostUserId], references: [id], onDelete: SetNull)
  recording  Recording?
  attendance Attendance[]

  @@index([tenantId])
  @@index([courseId])
  @@index([scheduledStart])
  @@index([deletedAt])
}

model Recording {
  id              String    @id @default(cuid())
  tenantId        String
  classSessionId  String    @unique
  status          String    @default("none")   // none | processing | ready | failed
  mediaUrl        String?
  transcriptUrl   String?
  durationSeconds Int?
  // AI products are NOT persisted as Recording fields — they live in
  // AiInteractionLog and are joined via the session id, so we never lie
  // about provenance.

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deletedAt])
}

model Attendance {
  id             String    @id @default(cuid())
  tenantId       String
  classSessionId String
  userId         String
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, userId, joinedAt])
  @@index([tenantId])
  @@index([classSessionId])
  @@index([userId])
}

// ---------- Assessments (quizzes + assignments) ----------
//
// One table for both shapes (see ADR 0007). `kind` discriminates:
//   - "quiz"       → questions answered in-app, auto-graded where possible
//   - "assignment" → free-form Submission.answers, manually graded
//
// `totalPoints` is denormalised so the catalog view doesn't need to sum
// over Question rows on every list query.

model Assessment {
  id            String    @id @default(cuid())
  tenantId      String
  courseId      String
  kind          String    // "quiz" | "assignment"
  title         String
  description   String?
  instructions  String?
  status        String    @default("draft")    // "draft" | "published" | "closed"
  totalPoints   Int       @default(0)
  dueAt         DateTime?
  publishedAt   DateTime?
  closedAt      DateTime?
  allowLate     Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions   Question[]
  submissions Submission[]

  @@index([tenantId])
  @@index([courseId])
  @@index([status])
  @@index([deletedAt])
}

model Question {
  id              String    @id @default(cuid())
  tenantId        String
  assessmentId    String
  kind            String    // "multiple_choice" | "short_answer" | "essay"
  prompt          String
  options         Json?     // [string, ...] for multiple_choice
  correctAnswer   Json?     // multiple_choice → number | number[]; short_answer → string
  points          Int       @default(1)
  orderIndex      Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([assessmentId])
  @@index([deletedAt])
}

model Submission {
  id            String    @id @default(cuid())
  tenantId      String
  assessmentId  String
  userId        String
  status        String    @default("draft")      // "draft" | "submitted" | "graded"
  answers       Json      @default("{}")         // { [questionId]: { selectedIndex?, text? } } | { text } for assignment
  autoScore     Int?
  grade         Float?                            // 0..100 percentage
  feedback      String?
  aiGradeDraft  Json?     // last envelope from /v1/assessment/grade-draft
  submittedAt   DateTime?
  gradedAt      DateTime?
  gradedBy      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, userId])
  @@index([tenantId])
  @@index([assessmentId])
  @@index([userId])
  @@index([deletedAt])
}

// ---------- Learning events ----------
//
// One row per observed action — emitted by service code at the seams
// (class-sessions.join, submissions.finalize, …) and by the SPA via
// POST /v1/learning-events for client-only signals (lesson_opened,
// ai_summary_viewed, confusion_reported).
//
// `type` is open-ended at the DB level (catalogue lives in docs/data/
// EVENT_CATALOG.md); the analytics service only relies on the curated
// types it knows about.

model LearningEvent {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?  // null for system-emitted events
  type            String
  courseId        String?
  lessonId        String?
  assessmentId    String?
  classSessionId  String?
  data            Json?
  occurredAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@index([occurredAt])
  @@index([courseId])
  @@index([assessmentId])
  @@index([classSessionId])
}

// ---------- AI audit log ----------
//
// Mandated by AGENTS.md: every AI Gateway response is persisted with its
// provenance + confidence + humanReviewRequired flag. The `requestId`
// matches the value in the ai-gateway response envelope so the two halves
// can be joined.

model AiInteractionLog {
  id                   String   @id @default(cuid())
  tenantId             String
  userId               String?
  requestId            String   @unique
  endpoint             String   // e.g. "/v1/rag/query"
  model                String
  provider             String
  mode                 String   // "mock" | "external_api"
  confidence           Float
  humanReviewRequired  Boolean
  request              Json
  response             Json
  latencyMs            Int?
  createdAt            DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([endpoint])
  @@index([createdAt])
}
