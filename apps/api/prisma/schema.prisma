// DigiUniversity core schema â€” Phase 2.
//
// Source of truth for the auth + tenant + RBAC + AI audit layer. The
// university domain (Faculty, Course, Enrollment, ClassSession, â€¦) lands
// in Phase 3 as additive migrations.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Tenants ----------
//
// Every domain row carries `tenantId`. We add an index per table so the
// "always filter by tenant" rule is also enforceable at the DB level.

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  roles           Role[]
  permissions     Permission[]
  refreshTokens   RefreshToken[]
  aiInteractions  AiInteractionLog[]
  faculties       Faculty[]
  departments     Department[]
  programs        Program[]
  courses         Course[]
  courseModules   CourseModule[]
  lessons         Lesson[]
  cohorts         Cohort[]
  enrollments     Enrollment[]

  @@index([slug])
}

// ---------- Identity ----------

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String?
  locale       String   @default("fa")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  aiInteractions AiInteractionLog[]
  enrollments    Enrollment[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ---------- RBAC ----------
//
// Roles and permissions are tenant-scoped so each tenant can shape its
// own access model. Three roles are seeded by default: admin, instructor,
// student. Permissions are colon-namespaced strings (resource:action).

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  name      String   // admin, instructor, student, ...
  label     String?  // human-readable, e.g. "Ů…ŘŻŰŚŘ± ŘłŘ§Ů…Ř§Ů†Ů‡"
  createdAt DateTime @default(now())

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id        String   @id @default(cuid())
  tenantId  String
  key       String   // e.g. "course:create", "user:invite"
  createdAt DateTime @default(now())

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ---------- Refresh tokens ----------
//
// Stored as the SHA-256 of the token (never the raw value) so a DB leak
// can't be used to mint sessions. Rotated on every /v1/auth/refresh call.

model RefreshToken {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ip         String?
  issuedAt   DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
}

// ---------- University domain ----------
//
// Org structure: Faculty â†’ Department â†’ Program â†’ (Course | Cohort).
// Course content: Course â†’ CourseModule â†’ Lesson.
// Membership: Enrollment ties a User to a Course (optionally inside a
// Cohort). Every row carries `tenantId` (filtered on every read) plus
// the audit fields (`createdAt`, `updatedAt`, `createdBy`, `updatedBy`)
// and a nullable `deletedAt` for soft delete â€” see docs/ADRs/0005.

model Faculty {
  id          String    @id @default(cuid())
  tenantId    String
  slug        String
  name        String
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments Department[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([deletedAt])
}

model Department {
  id          String    @id @default(cuid())
  tenantId    String
  facultyId   String
  slug        String
  name        String
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  faculty  Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  programs Program[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([facultyId])
  @@index([deletedAt])
}

model Program {
  id                String    @id @default(cuid())
  tenantId          String
  departmentId      String
  slug              String
  name              String
  description       String?
  degreeLevel       String    // "bachelor" | "master" | "phd" | "certificate"
  durationSemesters Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses    Course[]
  cohorts    Cohort[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([departmentId])
  @@index([deletedAt])
}

model Course {
  id          String    @id @default(cuid())
  tenantId    String
  programId   String
  code        String    // human-friendly identifier, e.g. "CS101"
  title       String
  description String?
  credits     Int       @default(3)
  language    String    @default("fa")
  level       String?   // "beginner" | "intermediate" | "advanced"

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  modules     CourseModule[]
  enrollments Enrollment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([programId])
  @@index([deletedAt])
}

model CourseModule {
  id          String    @id @default(cuid())
  tenantId    String
  courseId    String
  title       String
  description String?
  orderIndex  Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([tenantId])
  @@index([courseId])
  @@index([deletedAt])
}

model Lesson {
  id              String    @id @default(cuid())
  tenantId        String
  moduleId        String
  title           String
  contentMarkdown String?
  durationMinutes Int?
  orderIndex      Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([moduleId])
  @@index([deletedAt])
}

model Cohort {
  id        String    @id @default(cuid())
  tenantId  String
  programId String
  slug      String
  name      String
  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([programId])
  @@index([deletedAt])
}

model Enrollment {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  courseId    String
  cohortId    String?
  status      String    @default("active") // "active" | "completed" | "dropped" | "withdrawn"
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cohort Cohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId, courseId])
  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
  @@index([deletedAt])
}

// ---------- AI audit log ----------
//
// Mandated by AGENTS.md: every AI Gateway response is persisted with its
// provenance + confidence + humanReviewRequired flag. The `requestId`
// matches the value in the ai-gateway response envelope so the two halves
// can be joined.

model AiInteractionLog {
  id                   String   @id @default(cuid())
  tenantId             String
  userId               String?
  requestId            String   @unique
  endpoint             String   // e.g. "/v1/rag/query"
  model                String
  provider             String
  mode                 String   // "mock" | "external_api"
  confidence           Float
  humanReviewRequired  Boolean
  request              Json
  response             Json
  latencyMs            Int?
  createdAt            DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([endpoint])
  @@index([createdAt])
}
