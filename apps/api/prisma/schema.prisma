// DigiUniversity core schema — Phase 2.
//
// Source of truth for the auth + tenant + RBAC + AI audit layer. The
// university domain (Faculty, Course, Enrollment, ClassSession, …) lands
// in Phase 3 as additive migrations.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Tenants ----------
//
// Every domain row carries `tenantId`. We add an index per table so the
// "always filter by tenant" rule is also enforceable at the DB level.

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  roles           Role[]
  permissions     Permission[]
  refreshTokens   RefreshToken[]
  aiInteractions  AiInteractionLog[]
  auditLogs       AuditLog[]
  schools         School[]
  faculties       Faculty[]
  departments     Department[]
  programs        Program[]
  courses         Course[]
  courseModules   CourseModule[]
  lessons         Lesson[]
  cohorts         Cohort[]
  enrollments     Enrollment[]
  courseOfferings    CourseOffering[]
  migrationSyncLogs  MigrationSyncLog[]
  // Phase B R3.a (D68) — Identity track: tenant-scoped Student + Instructor rosters.
  // Profile is NOT tenant-relationed directly (tenant scope flows through Profile.user).
  students        Student[]
  instructors     Instructor[]
  classSessions   ClassSession[]
  recordings      Recording[]
  attendance      Attendance[]
  assessments     Assessment[]
  questions       Question[]
  submissions     Submission[]
  learningEvents  LearningEvent[]
  documents       Document[]
  documentChunks  DocumentChunk[]
  tutorSessions   TutorSession[]
  tutorMessages   TutorMessage[]

  @@index([slug])
}

// ---------- Identity ----------

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String?
  locale       String   @default("fa")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  aiInteractions AiInteractionLog[]
  auditedActions AuditLog[]         @relation("AuditLogActor")
  enrollments    Enrollment[]
  attendance     Attendance[]
  hostedSessions ClassSession[]     @relation("ClassSessionHost")
  submissions    Submission[]
  learningEvents LearningEvent[]
  tutorSessions  TutorSession[]
  tutorMessages  TutorMessage[]
  // Phase B R3.a (D68) — Identity track: strict 1:0..1 to Profile / Student / Instructor.
  // Profile is 1:1 enforced by Profile.userId UNIQUE per Q2.a; Student/Instructor
  // are 1:0..1 (a user may be only-student, only-instructor, both, or neither).
  profile        Profile?
  student        Student?
  instructor     Instructor?

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ---------- RBAC ----------
//
// Roles and permissions are tenant-scoped so each tenant can shape its
// own access model. Three roles are seeded by default: admin, instructor,
// student. Permissions are colon-namespaced strings (resource:action).

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  name      String   // admin, instructor, student, ...
  label     String?  // human-readable, e.g. "مدیر سامانه"
  createdAt DateTime @default(now())

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id        String   @id @default(cuid())
  tenantId  String
  key       String   // e.g. "course:create", "user:invite"
  createdAt DateTime @default(now())

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ---------- Refresh tokens ----------
//
// Stored as the SHA-256 of the token (never the raw value) so a DB leak
// can't be used to mint sessions. Rotated on every /v1/auth/refresh call.

model RefreshToken {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ip         String?
  issuedAt   DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
}

// ---------- University domain ----------
//
// Org structure: Faculty → Department → Program → (Course | Cohort).
// Course content: Course → CourseModule → Lesson.
// Membership: Enrollment ties a User to a Course (optionally inside a
// Cohort). Every row carries `tenantId` (filtered on every read) plus
// the audit fields (`createdAt`, `updatedAt`, `createdBy`, `updatedBy`)
// and a nullable `deletedAt` for soft delete — see docs/ADRs/0005.

// Phase B R1 (D63) — added BEFORE Faculty so the FK target is declared first.
// «دانشکده» / "School" sits one level above Faculty in the Academic Hierarchy:
// School → Faculty → Department → Program → (Course | Cohort).
// All fields except `nameFa` are nullable so existing Faculty rows can backfill
// schoolId at admin's pace (or stay null = "not yet assigned").
model School {
  id          String    @id @default(cuid())
  tenantId    String
  slug        String
  nameFa      String
  nameEn      String?
  shortCode   String?
  description String?
  iconName    String?
  sortOrder   Int       @default(0)
  charterDate DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  faculties Faculty[]

  @@unique([tenantId, slug])
  @@unique([tenantId, shortCode])
  @@index([tenantId])
  @@index([deletedAt])
}

model Faculty {
  id          String    @id @default(cuid())
  tenantId    String
  slug        String
  name        String
  description String?

  // Phase B R1 (D63) — additive Q4.a "spirit" columns (MIGRATION_POLICY §4).
  // `name` column above stays as the Persian source-of-truth (UI label
  // «نام فارسی»). `nameEn` is the optional English mirror.
  nameEn    String?
  shortCode String?
  schoolId  String?   // additive FK; existing rows backfill at admin's pace

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  school      School?      @relation(fields: [schoolId], references: [id])
  departments Department[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([schoolId])
  @@index([deletedAt])
}

model Department {
  id          String    @id @default(cuid())
  tenantId    String
  facultyId   String
  slug        String
  name        String
  description String?

  // Phase B R1 (D63) — additive Q4.a "spirit" columns.
  nameEn    String?
  shortCode String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  faculty     Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  programs    Program[]
  // Phase B R3.a (D68) — instructors are pinned to a department (nullable on Instructor
  // for floating/at-large hires; SetNull on dept delete keeps the instructor row alive).
  instructors Instructor[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([facultyId])
  @@index([deletedAt])
}

model Program {
  id                String    @id @default(cuid())
  tenantId          String
  departmentId      String
  slug              String
  name              String
  description       String?
  degreeLevel       String    // "bachelor" | "master" | "phd" | "certificate"
  durationSemesters Int?

  // Phase B R1 (D63) — additive Q4.a "spirit" columns.
  nameEn    String?
  shortCode String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department  Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses     Course[]
  cohorts     Cohort[]
  offerings   CourseOffering[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([departmentId])
  @@index([deletedAt])
}

model Course {
  id          String    @id @default(cuid())
  tenantId    String
  programId   String
  code        String    // human-friendly identifier, e.g. "CS101"
  title       String
  description String?
  credits     Int       @default(3)
  language    String    @default("fa")
  level       String?   // "beginner" | "intermediate" | "advanced"

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program        Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  modules        CourseModule[]
  enrollments    Enrollment[]
  classSessions  ClassSession[]
  assessments    Assessment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([programId])
  @@index([deletedAt])
}

model CourseModule {
  id          String    @id @default(cuid())
  tenantId    String
  courseId    String
  title       String
  description String?
  orderIndex  Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([tenantId])
  @@index([courseId])
  @@index([deletedAt])
}

model Lesson {
  id              String    @id @default(cuid())
  tenantId        String
  moduleId        String
  title           String
  contentMarkdown String?
  durationMinutes Int?
  orderIndex      Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([moduleId])
  @@index([deletedAt])
}

model Cohort {
  id        String    @id @default(cuid())
  tenantId  String
  programId String
  slug      String
  name      String
  startDate DateTime?
  endDate   DateTime?

  // Phase B R2 (D65) — additive backlink to the CourseOffering this
  // Cohort upgraded into (if any). Nullable for backward compat;
  // populated by the dual-write interceptor on first sync. Per
  // MIGRATION_POLICY §3 (existing-model modification, additive lane).
  upgradedToOfferingId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  // Cohort.upgradedToOfferingId → CourseOffering.id (no Prisma relation
  // declaration to avoid a tight FK constraint during the dual-write
  // window; the interceptor maintains referential integrity in app).

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([programId])
  @@index([deletedAt])
  @@index([upgradedToOfferingId])
}

model Enrollment {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  courseId    String
  cohortId    String?
  // Phase B R2 (D65) — additive dual-source FK to CourseOffering.
  // Nullable so existing enrollments (Cohort-only) keep working.
  // Set-null on offering soft-delete so the enrollment row survives.
  offeringId  String?
  status      String    @default("active") // "active" | "completed" | "dropped" | "withdrawn"
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cohort   Cohort?         @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  offering CourseOffering? @relation(fields: [offeringId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId, courseId])
  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
  @@index([offeringId])
  @@index([deletedAt])
}

// ---------- Class sessions, recordings, attendance ----------
//
// A ClassSession is one scheduled instance of a course meeting. It owns
// at most one Recording row (file metadata only — actual media lives in
// the storage abstraction described in docs/architecture/LIVE_CLASS.md).
// Attendance rows are appended when a user joins/leaves.
//
// `provider` + `providerMeetingId` + `joinUrl` are filled by whichever
// LiveClassProvider Nest resolves at boot (Phase 6 ships only the mock
// provider; LiveKit/BBB will plug in behind the same interface).

model ClassSession {
  id                String    @id @default(cuid())
  tenantId          String
  courseId          String
  hostUserId        String?   // instructor scheduling/leading the session
  title             String
  description       String?
  scheduledStart    DateTime
  scheduledEnd      DateTime
  actualStart       DateTime?
  actualEnd         DateTime?
  status            String    @default("scheduled") // scheduled | live | ended | cancelled
  joinPolicy        String    @default("enrolled")  // enrolled | public | invite
  provider          String    @default("mock")      // mock | livekit | bbb
  providerMeetingId String?
  joinUrl           String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course     Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  host       User?        @relation("ClassSessionHost", fields: [hostUserId], references: [id], onDelete: SetNull)
  recording  Recording?
  attendance Attendance[]

  @@index([tenantId])
  @@index([courseId])
  @@index([scheduledStart])
  @@index([deletedAt])
}

model Recording {
  id              String    @id @default(cuid())
  tenantId        String
  classSessionId  String    @unique
  status          String    @default("none")   // none | processing | ready | failed
  mediaUrl        String?
  transcriptUrl   String?
  durationSeconds Int?
  // AI products are NOT persisted as Recording fields — they live in
  // AiInteractionLog and are joined via the session id, so we never lie
  // about provenance.

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deletedAt])
}

model Attendance {
  id             String    @id @default(cuid())
  tenantId       String
  classSessionId String
  userId         String
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, userId, joinedAt])
  @@index([tenantId])
  @@index([classSessionId])
  @@index([userId])
}

// ---------- Assessments (quizzes + assignments) ----------
//
// One table for both shapes (see ADR 0007). `kind` discriminates:
//   - "quiz"       → questions answered in-app, auto-graded where possible
//   - "assignment" → free-form Submission.answers, manually graded
//
// `totalPoints` is denormalised so the catalog view doesn't need to sum
// over Question rows on every list query.

model Assessment {
  id            String    @id @default(cuid())
  tenantId      String
  courseId      String
  kind          String    // "quiz" | "assignment"
  title         String
  description   String?
  instructions  String?
  status        String    @default("draft")    // "draft" | "published" | "closed"
  totalPoints   Int       @default(0)
  dueAt         DateTime?
  publishedAt   DateTime?
  closedAt      DateTime?
  allowLate     Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions   Question[]
  submissions Submission[]

  @@index([tenantId])
  @@index([courseId])
  @@index([status])
  @@index([deletedAt])
}

model Question {
  id              String    @id @default(cuid())
  tenantId        String
  assessmentId    String
  kind            String    // "multiple_choice" | "short_answer" | "essay"
  prompt          String
  options         Json?     // [string, ...] for multiple_choice
  correctAnswer   Json?     // multiple_choice → number | number[]; short_answer → string
  points          Int       @default(1)
  orderIndex      Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([assessmentId])
  @@index([deletedAt])
}

model Submission {
  id            String    @id @default(cuid())
  tenantId      String
  assessmentId  String
  userId        String
  status        String    @default("draft")      // "draft" | "submitted" | "graded"
  answers       Json      @default("{}")         // { [questionId]: { selectedIndex?, text? } } | { text } for assignment
  autoScore     Int?
  grade         Float?                            // 0..100 percentage
  feedback      String?
  aiGradeDraft  Json?     // last envelope from /v1/assessment/grade-draft
  submittedAt   DateTime?
  gradedAt      DateTime?
  gradedBy      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, userId])
  @@index([tenantId])
  @@index([assessmentId])
  @@index([userId])
  @@index([deletedAt])
}

// ---------- Learning events ----------
//
// One row per observed action — emitted by service code at the seams
// (class-sessions.join, submissions.finalize, …) and by the SPA via
// POST /v1/learning-events for client-only signals (lesson_opened,
// ai_summary_viewed, confusion_reported).
//
// `type` is open-ended at the DB level (catalogue lives in docs/data/
// EVENT_CATALOG.md); the analytics service only relies on the curated
// types it knows about.

model LearningEvent {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?  // null for system-emitted events
  type            String
  courseId        String?
  lessonId        String?
  assessmentId    String?
  classSessionId  String?
  data            Json?
  occurredAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@index([occurredAt])
  @@index([courseId])
  @@index([assessmentId])
  @@index([classSessionId])
}

// ---------- RAG corpus + tutor ----------
//
// Phase 9 ships the *control plane* — documents are persisted with
// chunked text so future ai-gateway / external GPU work can index them
// without another migration. The vector column is JSON so we can switch
// to pgvector by changing one ALTER without losing rows.

model Document {
  id          String    @id @default(cuid())
  tenantId    String
  courseId    String?
  title       String
  source      String?   // URL or storage URI, optional
  kind        String    @default("text") // "text" | "pdf" | "external"
  content     String    @db.Text         // raw text — small for MVP
  language    String    @default("fa")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]

  @@index([tenantId])
  @@index([courseId])
  @@index([deletedAt])
}

model DocumentChunk {
  id           String   @id @default(cuid())
  tenantId     String
  documentId   String
  orderIndex   Int      @default(0)
  text         String   @db.Text
  tokenCount   Int?
  embedding    Json?    // placeholder for future vectors

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([documentId])
}

model TutorSession {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String
  courseId      String?   // optional: scoped to a course
  title         String    @default("گفت‌و‌گوی جدید")
  lastMessageAt DateTime  @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TutorMessage[]

  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
  @@index([lastMessageAt])
  @@index([deletedAt])
}

model TutorMessage {
  id             String    @id @default(cuid())
  tenantId       String
  sessionId      String
  userId         String?   // null for assistant turns
  role           String    // "user" | "assistant" | "system"
  content        String    @db.Text
  citations      Json?     // [{ id, title, score }, ...] for assistant turns
  aiRequestId    String?   // joins to AiInteractionLog.requestId
  confidence     Float?
  humanReviewRequired Boolean?

  createdAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([sessionId])
  @@index([createdAt])
}

// ---------- AI audit log ----------
//
// Mandated by AGENTS.md: every AI Gateway response is persisted with its
// provenance + confidence + humanReviewRequired flag. The `requestId`
// matches the value in the ai-gateway response envelope so the two halves
// can be joined.

model AiInteractionLog {
  id                   String   @id @default(cuid())
  tenantId             String
  userId               String?
  requestId            String   @unique
  endpoint             String   // e.g. "/v1/rag/query"
  model                String
  provider             String
  mode                 String   // "mock" | "external_api"
  confidence           Float
  humanReviewRequired  Boolean
  request              Json
  response             Json
  latencyMs            Int?
  createdAt            DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([endpoint])
  @@index([createdAt])
}

// ---------- Generic audit log ----------
//
// Phase-15 R1. AiInteractionLog captures AI-specific calls;
// LearningEvent captures user-facing learning events. This model is
// the catch-all for SENSITIVE STATE-CHANGING ACTIONS — role grants,
// course publish/delete, refunds, tenant config changes, anything
// that should be reconstructable from the log if disputed.
//
// Written by the audit interceptor on every successful mutating
// endpoint (Phase 15 R2). The `before`/`after` JSON columns hold the
// resource snapshot pre/post mutation so the diff is reconstructable.
// `requestId` joins to API access logs + AiInteractionLog so a
// timeline can be reconstructed across the stack.

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  /// null when the action is performed by the system (cron, seeder, etc.)
  actorId     String?
  /// Dotted resource:verb identifier, e.g. "course.create", "user.role.change",
  /// "submission.grade", "tenant.delete".
  action      String
  /// Free-form subject identifier, e.g. "Course:abc123", "User:def456".
  /// Two fields rather than (subjectType, subjectId) tuple so it can be
  /// indexed as a single string and joined to whatever resource id format
  /// the source domain uses.
  subject     String
  /// Pre-mutation snapshot (or null on create).
  before      Json?
  /// Post-mutation snapshot (or null on delete).
  after       Json?
  ip          String?  @db.VarChar(64)
  userAgent   String?  @db.VarChar(512)
  /// Joins to AiInteractionLog.requestId and the API access log.
  requestId   String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@index([action])
  @@index([subject])
  @@index([requestId])
}

// ---------- Phase B R2 (D65) — CourseOffering + dual-write infra ----------
//
// CourseOffering is the modern replacement for Cohort. Both ship in
// parallel during the dual-write window per MIGRATION_POLICY §3 + §5;
// a 4-sprint Sunset window precedes Cohort removal. The interceptor in
// `apps/api/src/university/course-offerings/legacy-sync.service.ts`
// keeps Cohort.upgradedToOfferingId + Enrollment.offeringId in sync.
// instructorId DEFERRED to R3 (Identity track) per D65 Q2 modification.

enum OfferingStatus {
  SCHEDULED
  OPEN
  ACTIVE
  COMPLETED
  CANCELED
}

enum OfferingMode {
  SYNCHRONOUS
  ASYNCHRONOUS
  HYBRID
}

model CourseOffering {
  id             String         @id @default(cuid())
  tenantId       String
  programId      String
  slug           String
  nameFa         String
  nameEn         String?
  shortCode      String?
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  capacity       Int?
  mode           OfferingMode   @default(SYNCHRONOUS)
  status         OfferingStatus @default(SCHEDULED)
  /// Cohort.id this offering was upgraded FROM, if any. Populated by
  /// the dual-write interceptor on first migration. Nullable for
  /// greenfield offerings that never had a Cohort predecessor.
  legacyCohortId String?
  /// Phase B R3.a (D68 Q3.a) — single lead instructor per offering.
  /// Nullable so an offering can exist before staffing; SetNull on
  /// Instructor soft-delete so the offering survives instructor
  /// departures (admin can reassign via UI). Future team-teaching is
  /// an additive junction model in R4+ per MIGRATION_POLICY §4 + §5.
  instructorId   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  instructor  Instructor?  @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  enrollments Enrollment[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([programId])
  @@index([legacyCohortId])
  @@index([instructorId])
  @@index([deletedAt])
}

// MigrationSyncLog — append-only audit trail of dual-write events.
// Every Cohort↔CourseOffering sync writes a row here so the drop
// gate (7 consecutive days of zero legacy traffic) can be measured.
// Per MIGRATION_POLICY §1.
model MigrationSyncLog {
  id        String   @id @default(cuid())
  tenantId  String
  source    String   // "Cohort" | "CourseOffering"
  target    String   // mirror of source for the other direction
  rowId     String   // source-side row id
  targetId  String?  // newly-created or matched target row id
  action    String   // "create" | "update" | "delete" | "backfill"
  notes     String?
  syncedAt  DateTime @default(now())
  syncedBy  String?  // user id who triggered, or "system" for backfills

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, syncedAt])
  @@index([source, syncedAt])
  @@index([rowId])
}

// ---------- Phase B R3.a (D68) — Identity track ----------
//
// Profile / Student / Instructor sit on top of the existing User model
// (which carries authn + RBAC). The split is per Q2.a + Q3.a:
//   • Profile  — strict 1:1 with User (personal info: bio, dob, phone,
//                avatar, address, nationalId, optional locale override).
//                Self-service editable via @SelfOrAdmin guard per D69.
//   • Student  — 1:0..1 with User. Holds enrollment lifecycle status
//                + admission metadata. Created either by admin (R3.a)
//                or by R3.b StudentApplication acceptance side effect.
//   • Instructor — 1:0..1 with User. Holds department assignment, rank,
//                expertise tags, hire date. Created either by admin
//                (R3.a) or by R3.b InstructorApplication acceptance.
//
// State machines (StudentApplication, InstructorApplication, status
// transition guards) defer to R3.b per D68. R3.a treats `status` as
// a plain enum that admins can set freely; no transition validation
// until R3.b ships.

enum StudentStatus {
  ENROLLED
  ON_LEAVE
  GRADUATED
  WITHDRAWN
  DISMISSED
}

enum InstructorStatus {
  ACTIVE
  ON_SABBATICAL
  INACTIVE
  TERMINATED
}

enum InstructorRank {
  ASSISTANT
  ASSOCIATE
  FULL
  EMERITUS
}

model Profile {
  id          String    @id @default(cuid())
  /// Strict 1:1 with User per Q2.a — enforced by @unique.
  userId      String    @unique
  bio         String?   @db.Text
  dateOfBirth DateTime?
  phoneNumber String?
  avatarUrl   String?
  address     String?   @db.Text
  /// Optional Iranian national ID. Used by R3.b applicant verification
  /// + de-duplication. R3.a stores it without validation.
  nationalId  String?
  /// Optional per-user override of User.locale. NULL = use User.locale.
  locale      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
}

model Student {
  id            String        @id @default(cuid())
  tenantId      String
  /// 1:0..1 with User — enforced by @unique. A user may be only-instructor.
  userId        String        @unique
  /// Human-readable, tenant-unique. e.g. "STU-40219".
  studentCode   String
  admissionDate DateTime?
  status        StudentStatus @default(ENROLLED)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, studentCode])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model Instructor {
  id             String           @id @default(cuid())
  tenantId       String
  /// 1:0..1 with User — enforced by @unique.
  userId         String           @unique
  /// Human-readable, tenant-unique. e.g. "INS-781".
  instructorCode String
  /// Department pinning. Nullable for floating/at-large hires.
  /// SetNull on Department delete so the Instructor row survives a
  /// dept reorg (admin reassigns via UI).
  departmentId   String?
  rank           InstructorRank?
  /// Free-text expertise tags. Controlled vocabulary deferred to R4+
  /// per memo risks section.
  expertise      String[]
  hireDate       DateTime?
  status         InstructorStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department      Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  /// Reverse for R2 instructorId wire (Q3.a). One instructor → many offerings.
  taughtOfferings CourseOffering[]

  @@unique([tenantId, instructorCode])
  @@index([tenantId, status])
  @@index([departmentId])
  @@index([deletedAt])
}
