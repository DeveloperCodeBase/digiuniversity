    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.19",
    "tailwindcss-rtl": "^0.9.0",
